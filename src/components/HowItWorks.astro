---
interface Step {
	accent?: 'compute' | 'ai' | 'media' | 'storage' | 'sase';
	title: string;
	body: string;
}

interface Props {
	title?: string;
	subtitle?: string;
	steps?: Step[];
}

const defaultSteps: Step[] = [
	{
		accent: 'compute',
		title: 'Capture frames',
		body: 'Camera frames are sampled in-browser, downscaled to JPEG, and sent over HTTPS at roughly 1.5 fps.',
	},
	{
		accent: 'ai',
		title: 'Run Workers AI',
		body: "The Astro API route calls the Workers AI binding and runs Meta's DETR ResNet-50 object detector.",
	},
	{
		accent: 'media',
		title: 'Render detections',
		body: 'The browser scales model coordinates back to the video overlay and draws labels with confidence scores.',
	},
];

const {
	title = 'Frame by frame, edge by edge',
	subtitle = "The demo keeps the browser lightweight and lets Workers AI perform the expensive vision step on Cloudflare's network.",
	steps = defaultSteps,
} = Astro.props;
---

<section class="how-it-works container" aria-labelledby="how-it-works-title">
	<div class="section-heading">
		<h2 id="how-it-works-title">{title}</h2>
		<p>{subtitle}</p>
	</div>

	<div class="steps-grid">
		{steps.map((step) => (
			<article class="feature-card corner-card scroll-reveal">
				<span class="corner-top-right"></span>
				<span class="corner-bottom-left"></span>
				<div class:list={['icon', step.accent ?? 'compute']} aria-hidden="true">
					<svg viewBox="0 0 24 24">
						<path d="M15 10.5 21 6l-6-4.5v9Zm0 3v9L21 18l-6-4.5ZM3 6l6 4.5v-9L3 6Zm0 12l6 4.5v-9L3 18Zm9-5.5L6.5 9 12 5.5 17.5 9 12 12.5Zm0 6L6.5 15 12 11.5 17.5 15 12 18.5Z"></path>
					</svg>
				</div>
				<h3>{step.title}</h3>
				<p>{step.body}</p>
			</article>
		))}
	</div>
</section>

<style>
	.how-it-works {
		padding-block: 44px 64px;
	}

	.section-heading {
		max-width: 720px;
		margin-inline: auto;
		text-align: center;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 500;
		line-height: 1;
		letter-spacing: -0.04em;
		text-wrap: balance;
	}

	.section-heading p {
		margin: 14px 0 0;
		font-size: 17px;
		line-height: 1.5;
		color: var(--cf-text-muted);
		text-wrap: balance;
	}

	.steps-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 16px;
		margin-top: 28px;
	}

	.feature-card {
		padding: 24px;
		background: var(--cf-bg-200);
		border: 1px solid var(--cf-border);
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-card);
		transition:
			box-shadow var(--duration-normal) var(--ease-out),
			transform var(--duration-normal) var(--ease-out),
			background-color var(--duration-normal) var(--ease-out);
	}

	.feature-card:hover {
		background: var(--cf-bg-300);
		box-shadow: var(--shadow-lg);
		transform: translateY(-2px);
	}

	.icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		margin-bottom: 18px;
		border-radius: var(--radius-lg);
	}

	.icon svg {
		width: 22px;
		height: 22px;
		fill: currentColor;
	}

	.compute {
		color: var(--cf-compute);
		background: rgba(10, 149, 255, 0.1);
	}

	.ai {
		color: color-mix(in srgb, var(--cf-ai) 82%, #166534);
		background: var(--cf-ai-bg);
	}

	.media {
		color: var(--cf-media);
		background: rgba(150, 22, 255, 0.1);
	}

	.storage {
		color: var(--cf-storage);
		background: rgba(238, 13, 219, 0.1);
	}

	.sase {
		color: var(--cf-sase);
		background: rgba(13, 148, 136, 0.1);
	}

	h3 {
		margin: 0 0 8px;
		font-size: 20px;
		font-weight: 500;
		letter-spacing: -0.02em;
	}

	.feature-card p {
		margin: 0;
		font-size: 15px;
		line-height: 1.55;
		color: var(--cf-text-muted);
	}

	@media (min-width: 780px) {
		.steps-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 20px;
			margin-top: 36px;
		}
	}
</style>
