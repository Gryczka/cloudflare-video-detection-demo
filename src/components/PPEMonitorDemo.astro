<section id="demo" class="demo-section container scroll-reveal" aria-labelledby="ppe-title">
	<div class="demo-card corner-card" data-ppe-demo>
		<span class="corner-top-right"></span>
		<span class="corner-bottom-left"></span>

		<div class="demo-header">
			<div>
				<p class="eyebrow">Construction safety analytics</p>
				<h2 id="ppe-title">Detect missing headwear</h2>
			</div>
			<div class="status-badge" aria-live="polite">
				<span class="status-dot" aria-hidden="true"></span>
				<span data-status-text>Idle</span>
			</div>
		</div>

		<div class="model-selector" role="group" aria-label="Vision model selector">
			<button class="model-button active" type="button" data-model-button data-model="llama">Llama Vision</button>
			<button class="model-button" type="button" data-model-button data-model="llava">LLaVA</button>
			<button class="model-button" type="button" data-model-button data-model="gemma">Gemma 4</button>
		</div>
		<div class="target-selector" role="group" aria-label="Required headwear selector">
			<span class="selector-label">Check for</span>
			<button class="target-button active" type="button" data-target-button data-target="hardhat">Hardhat</button>
			<button class="target-button" type="button" data-target-button data-target="baseball-cap">Baseball cap</button>
		</div>

		<div class="demo-grid">
			<div class="video-panel">
				<div class="video-stage" data-video-stage>
					<video id="ppe-camera-video" muted playsinline></video>
					<canvas id="ppe-overlay-canvas" aria-hidden="true"></canvas>
					<div class="empty-state" data-empty-state>
						<div class="camera-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24"><path d="M12 2 4 5v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V5l-8-3Zm0 2.13L18 6.4V11c0 4.55-2.9 8.55-6 9.87C8.9 19.55 6 15.55 6 11V6.4l6-2.27Zm-2 5.62h4v2h-4v-2Zm-1 4h6v2H9v-2Z"></path></svg>
						</div>
						<p data-empty-title>Start the camera to assess hardhat compliance with Workers AI.</p>
						<span data-empty-copy>DETR tracks people quickly; the selected vision model checks hardhats every few seconds.</span>
					</div>
				</div>

				<canvas id="ppe-capture-buffer" width="640" height="360" hidden></canvas>

				<div class="controls" aria-label="PPE monitor controls">
					<button class="control-button primary" type="button" data-start-button>Start camera</button>
					<button class="control-button analyze" type="button" data-analyze-button hidden disabled>Analyze frame</button>
					<button class="control-button ghost" type="button" data-pause-button disabled>Pause stream</button>
					<button class="control-button outline" type="button" data-switch-button disabled>Switch camera</button>
				</div>

				<div class="error-panel" data-error-panel hidden role="alert"></div>
			</div>

			<aside class="assessment-panel" aria-labelledby="ppe-assessment-title">
				<div class="panel-heading">
					<div>
						<p class="eyebrow">PPE assessment</p>
						<h3 id="ppe-assessment-title" data-assessment-title>Hardhat status</h3>
					</div>
					<span class="threshold" data-active-model>@cf/meta/llama-3.2-11b-vision-instruct</span>
				</div>

				<div class="assessment-summary" data-assessment-summary>
					<p>No PPE assessment yet.</p>
				</div>

				<ul class="event-log" data-event-log aria-live="polite">
					<li class="placeholder">Violations will appear here.</li>
				</ul>
			</aside>
		</div>

		<div class="stats-grid" aria-label="PPE monitor metrics">
			<div class="stat-card"><span>People boxes</span><strong data-stat-persons>0</strong></div>
			<div class="stat-card"><span data-compliant-label>With hardhat</span><strong data-stat-compliant>-</strong></div>
			<div class="stat-card"><span data-violation-label>Missing hardhat</span><strong data-stat-violations>-</strong></div>
			<div class="stat-card"><span>PPE latency</span><strong data-stat-ppe-latency>-</strong></div>
			<div class="stat-card"><span>Last check</span><strong data-stat-last-check>-</strong></div>
			<div class="stat-card"><span>Frame latency</span><strong data-stat-detect-latency>-</strong></div>
		</div>
	</div>
</section>

<script is:inline>
	(() => {
		const root = document.querySelector('[data-ppe-demo]');
		if (!root) return;

		const sampleMs = 1000;
		const ppeMs = 3000;
		const minScore = 0.55;
		const captureWidth = 640;
		const captureHeight = 360;
		const models = {
			llama: '@cf/meta/llama-3.2-11b-vision-instruct',
			llava: '@cf/llava-hf/llava-1.5-7b-hf',
			gemma: '@cf/google/gemma-4-26b-a4b-it',
		};
		const targets = {
			'hardhat': {
				label: 'hardhat',
				plural: 'hardhats',
				statusLabel: 'Hardhat',
				display: 'Hardhat',
			},
			'baseball-cap': {
				label: 'baseball cap',
				plural: 'baseball caps',
				statusLabel: 'Cap',
				display: 'Baseball cap',
			},
		};

		const refs = {
			video: root.querySelector('#ppe-camera-video'),
			overlay: root.querySelector('#ppe-overlay-canvas'),
			buffer: root.querySelector('#ppe-capture-buffer'),
			stage: root.querySelector('[data-video-stage]'),
			empty: root.querySelector('[data-empty-state]'),
			statusText: root.querySelector('[data-status-text]'),
			startButton: root.querySelector('[data-start-button]'),
			analyzeButton: root.querySelector('[data-analyze-button]'),
			pauseButton: root.querySelector('[data-pause-button]'),
			switchButton: root.querySelector('[data-switch-button]'),
			errorPanel: root.querySelector('[data-error-panel]'),
			modelButtons: root.querySelectorAll('[data-model-button]'),
			targetButtons: root.querySelectorAll('[data-target-button]'),
			activeModel: root.querySelector('[data-active-model]'),
			assessmentTitle: root.querySelector('[data-assessment-title]'),
			emptyTitle: root.querySelector('[data-empty-title]'),
			emptyCopy: root.querySelector('[data-empty-copy]'),
			summary: root.querySelector('[data-assessment-summary]'),
			eventLog: root.querySelector('[data-event-log]'),
			persons: root.querySelector('[data-stat-persons]'),
			compliantLabel: root.querySelector('[data-compliant-label]'),
			violationLabel: root.querySelector('[data-violation-label]'),
			compliant: root.querySelector('[data-stat-compliant]'),
			violations: root.querySelector('[data-stat-violations]'),
			ppeLatency: root.querySelector('[data-stat-ppe-latency]'),
			lastCheck: root.querySelector('[data-stat-last-check]'),
			detectLatency: root.querySelector('[data-stat-detect-latency]'),
		};

		let stream = null;
		let detectionInterval = null;
		let ppeInterval = null;
		let ageInterval = null;
		let detectInFlight = null;
		let ppeInFlight = null;
		let facingMode = 'environment';
		// Safe default: treat as demo (manual single-shot) until /api/demo-status
		// confirms otherwise, so we never auto-loop the expensive vision model.
		let ppeManual = true;
		let selectedModel = 'llama';
		let selectedTarget = 'hardhat';
		let people = [];
		let lastAssessment = null;
		let lastAssessmentAt = null;
		let lastViolationCount = 0;
		let lastEventAt = 0;
		let events = [];

		const overlayContext = refs.overlay.getContext('2d');
		const bufferContext = refs.buffer.getContext('2d', { willReadFrequently: false });

		function setStatus(text, state) {
			refs.statusText.textContent = text;
			root.dataset.status = state;
		}

		function setError(message) {
			refs.errorPanel.hidden = false;
			refs.errorPanel.textContent = message;
			setStatus('Error', 'error');
		}

		function clearError() {
			refs.errorPanel.hidden = true;
			refs.errorPanel.textContent = '';
			refs.errorPanel.classList.remove('is-demo-limit');
		}

		function showDemoLimit(body) {
			const url = body && body.selfHostUrl;
			const msg = (body && body.error) || 'Open demo limit reached.';
			refs.errorPanel.hidden = false;
			refs.errorPanel.classList.add('is-demo-limit');
			refs.errorPanel.innerHTML =
				escapeHtml(msg) +
				(url ? ` <a href="${escapeHtml(url)}" target="_blank" rel="noopener">Run your own →</a>` : '');
			setStatus('Demo limit', 'idle');
		}

		function configureMode() {
			refs.analyzeButton.hidden = !ppeManual;
			updateTargetCopy();
			if (!ppeManual && stream && !ppeInterval) {
				captureAndAssessPPE();
				ppeInterval = window.setInterval(captureAndAssessPPE, ppeMs);
			}
		}

		function sizeCanvases() {
			const rect = refs.stage.getBoundingClientRect();
			refs.overlay.width = Math.max(1, Math.round(rect.width));
			refs.overlay.height = Math.max(1, Math.round(rect.height));
			refs.buffer.width = captureWidth;
			refs.buffer.height = captureHeight;
			renderOverlay();
		}

		async function startCamera() {
			clearError();
			if (!navigator.mediaDevices?.getUserMedia) {
				setError('This browser does not expose getUserMedia. Try a current desktop or mobile browser.');
				return;
			}
			if (!window.isSecureContext && location.hostname !== 'localhost') {
				setError('Camera capture requires HTTPS. Deploy to workers.dev or run on localhost.');
				return;
			}

			setStatus('Requesting camera', 'pending');
			refs.startButton.disabled = true;
			try {
				stream = await navigator.mediaDevices.getUserMedia({
					audio: false,
					video: { facingMode, width: { ideal: 1280 }, height: { ideal: 720 } },
				});
				refs.video.srcObject = stream;
				await refs.video.play();
				refs.empty.hidden = true;
				refs.pauseButton.disabled = false;
				refs.switchButton.disabled = false;
				refs.analyzeButton.disabled = false;
				sizeCanvases();
				setStatus('Scanning', 'streaming');
				startLoops();
			} catch (error) {
				refs.startButton.disabled = false;
				setError(error?.name === 'NotAllowedError' ? 'Camera permission was denied. Allow camera access and try again.' : 'Could not start the camera on this device.');
			}
		}

		function stopCamera() {
			stopLoops();
			if (stream) for (const track of stream.getTracks()) track.stop();
			stream = null;
			refs.video.srcObject = null;
			people = [];
			refs.empty.hidden = false;
			refs.startButton.disabled = false;
			refs.pauseButton.disabled = true;
			refs.switchButton.disabled = true;
			refs.analyzeButton.disabled = true;
			setStatus('Paused', 'idle');
			renderOverlay();
		}

		function startLoops() {
			if (!detectionInterval) {
				captureAndDetect();
				detectionInterval = window.setInterval(captureAndDetect, sampleMs);
			}
			// In demo mode the expensive vision model runs only on demand
			// (the "Analyze frame" button), never on a continuous loop.
			if (!ppeManual && !ppeInterval) {
				captureAndAssessPPE();
				ppeInterval = window.setInterval(captureAndAssessPPE, ppeMs);
			}
			if (!ageInterval) ageInterval = window.setInterval(updateAssessmentAge, 1000);
		}

		function stopLoops() {
			if (detectionInterval) window.clearInterval(detectionInterval);
			if (ppeInterval) window.clearInterval(ppeInterval);
			if (ageInterval) window.clearInterval(ageInterval);
			detectionInterval = null;
			ppeInterval = null;
			ageInterval = null;
			if (detectInFlight) detectInFlight.abort();
			if (ppeInFlight) ppeInFlight.abort();
			detectInFlight = null;
			ppeInFlight = null;
		}

		async function switchCamera() {
			facingMode = facingMode === 'environment' ? 'user' : 'environment';
			stopCamera();
			await startCamera();
		}

		function drawCurrentFrame() {
			if (!stream || refs.video.readyState < HTMLMediaElement.HAVE_CURRENT_DATA) return false;
			sizeCanvases();
			bufferContext.drawImage(refs.video, 0, 0, captureWidth, captureHeight);
			return true;
		}

		async function captureBlob() {
			if (!drawCurrentFrame()) return null;
			return await new Promise((resolve) => refs.buffer.toBlob(resolve, 'image/jpeg', 0.7));
		}

		async function captureAndDetect() {
			if (!stream || detectInFlight) return;
			const blob = await captureBlob();
			if (!blob) return;
			const controller = new AbortController();
			detectInFlight = controller;
			const started = performance.now();
			try {
				const response = await fetch('/api/detect', {
					method: 'POST',
					body: blob,
					headers: { 'content-type': 'image/jpeg' },
					signal: controller.signal,
				});
				if (!response.ok) {
					const body = await response.json().catch(() => ({}));
					if (body && body.demoLimit) {
						showDemoLimit(body);
						if (body.reason === 'demo_daily_cap') stopLoops();
						return;
					}
					throw new Error(body.error || 'Person detection failed.');
				}
				const payload = await response.json();
				people = (Array.isArray(payload.detections) ? payload.detections : [])
					.map(normalizeDetection)
					.filter(Boolean)
					.filter((d) => d.label.toLowerCase() === 'person' && d.score >= minScore);
				refs.persons.textContent = String(people.length);
				refs.detectLatency.textContent = `${Math.round(performance.now() - started)} ms`;
				renderOverlay();
			} catch (error) {
				if (error?.name !== 'AbortError') setError(error?.message || 'Person detection failed.');
			} finally {
				if (detectInFlight === controller) detectInFlight = null;
			}
		}

		async function captureAndAssessPPE() {
			if (!stream || ppeInFlight) return;
			const blob = await captureBlob();
			if (!blob) return;
			const controller = new AbortController();
			ppeInFlight = controller;
			setStatus('Assessing PPE', 'detecting');
			try {
				const response = await fetch(`/api/ppe?model=${encodeURIComponent(selectedModel)}&target=${encodeURIComponent(selectedTarget)}`, {
					method: 'POST',
					body: blob,
					headers: { 'content-type': 'image/jpeg' },
					signal: controller.signal,
				});
				const payload = await response.json();
				if (!response.ok) {
					if (payload && payload.demoLimit) {
						showDemoLimit(payload);
						if (payload.reason === 'demo_daily_cap' && ppeInterval) {
							window.clearInterval(ppeInterval);
							ppeInterval = null;
						}
						return;
					}
					throw new Error(payload.error || 'PPE assessment failed.');
				}
				lastAssessment = payload.assessment;
				lastAssessmentAt = Date.now();
				refs.ppeLatency.textContent = `${Math.round(payload.inferenceMs || 0)} ms`;
				renderAssessment(payload.raw || '');
				renderOverlay();
			} catch (error) {
				if (error?.name !== 'AbortError') setError(error?.message || 'PPE assessment failed.');
			} finally {
				if (ppeInFlight === controller) ppeInFlight = null;
			}
		}

		function renderAssessment(raw) {
			if (!lastAssessment) {
				refs.summary.innerHTML = `<p>Could not parse a structured PPE result.</p><details><summary>Raw response</summary><pre>${escapeHtml(raw)}</pre></details>`;
				setStatus('Parse error', 'error');
				return;
			}
			const personCount = Number(lastAssessment.person_count || 0);
			const persons = Array.isArray(lastAssessment.persons) ? lastAssessment.persons : [];
			const target = targets[selectedTarget];
			const compliant = persons.filter((person) => person.wearing_target ?? person.wearing_hardhat).length;
			const violations = Math.max(0, personCount - compliant);
			refs.compliant.textContent = String(compliant);
			refs.violations.textContent = String(violations);
			refs.summary.innerHTML = `<div class="summary-cards"><span><b>${personCount}</b> people</span><span><b>${compliant}</b> ${escapeHtml(target.plural)}</span><span class="${violations ? 'danger' : 'safe'}"><b>${violations}</b> missing</span></div>${renderPeopleList(persons)}`;
			updateViolationEvents(personCount, violations);
			setStatus(violations > 0 ? 'Violation detected' : 'Compliant', violations > 0 ? 'violation' : 'safe');
		}

		function renderPeopleList(persons) {
			if (!persons.length) return '<p class="assessment-note">No visible people in the last PPE check.</p>';
			const target = targets[selectedTarget];
			return `<ul class="people-list">${persons.map((person, index) => {
				const wearingTarget = person.wearing_target ?? person.wearing_hardhat;
				return `<li><span>${index + 1}. ${escapeHtml(person.location || 'visible person')}</span><b class="${wearingTarget ? 'safe' : 'danger'}">${wearingTarget ? escapeHtml(target.statusLabel) : 'Missing'}</b></li>`;
			}).join('')}</ul>`;
		}

		function updateViolationEvents(personCount, violations) {
			const now = Date.now();
			if (violations === lastViolationCount || now - lastEventAt < 2000) return;
			const target = targets[selectedTarget];
			if (violations > 0) logEvent(`PPE violation detected: ${violations} of ${personCount} missing ${target.label}`, violations);
			else if (lastViolationCount > 0) logEvent(`All visible people have ${target.plural}`, 0);
			lastViolationCount = violations;
			lastEventAt = now;
		}

		function logEvent(message, count) {
			events.unshift({ time: new Date(), message, count });
			events = events.slice(0, 50);
			renderEvents();
		}

		function renderEvents() {
			if (!events.length) {
				refs.eventLog.innerHTML = '<li class="placeholder">Violations will appear here.</li>';
				return;
			}
			refs.eventLog.innerHTML = events.map((event) => `<li><span><strong>${escapeHtml(event.message)}</strong><small>${event.time.toLocaleTimeString()}</small></span><b>${event.count}</b></li>`).join('');
		}

		function updateAssessmentAge() {
			refs.lastCheck.textContent = lastAssessmentAt ? `${Math.round((Date.now() - lastAssessmentAt) / 1000)}s ago` : '-';
		}

		function renderOverlay() {
			overlayContext.clearRect(0, 0, refs.overlay.width, refs.overlay.height);
			const sx = refs.overlay.width / captureWidth;
			const sy = refs.overlay.height / captureHeight;
			const color = assessmentColor();
			for (const person of people) {
				const x = person.box.xmin * sx;
				const y = person.box.ymin * sy;
				const w = (person.box.xmax - person.box.xmin) * sx;
				const h = (person.box.ymax - person.box.ymin) * sy;
				overlayContext.strokeStyle = color;
				overlayContext.lineWidth = color === '#DC2626' ? 4 : 2;
				overlayContext.strokeRect(x, y, w, h);
				const text = color === '#DC2626' ? `Missing ${targets[selectedTarget].label}` : color === '#16A34A' ? `${targets[selectedTarget].display} detected` : 'person detected';
				drawLabel(x, Math.max(0, y - 22), text, color);
			}
		}

		function assessmentColor() {
			if (!lastAssessment) return '#FF4801';
			const persons = Array.isArray(lastAssessment.persons) ? lastAssessment.persons : [];
			const compliant = persons.filter((person) => person.wearing_target ?? person.wearing_hardhat).length;
			const violations = Math.max(0, Number(lastAssessment.person_count || 0) - compliant);
			return violations > 0 ? '#DC2626' : Number(lastAssessment.person_count || 0) > 0 ? '#16A34A' : '#FF4801';
		}

		function drawLabel(x, y, text, color) {
			overlayContext.font = '12px ui-monospace, SFMono-Regular, Menlo, monospace';
			const width = overlayContext.measureText(text).width + 12;
			overlayContext.fillStyle = color;
			roundedRect(overlayContext, x, y, width, 20, 5);
			overlayContext.fill();
			overlayContext.fillStyle = '#FFFBF5';
			overlayContext.fillText(text, x + 6, y + 14);
		}

		function normalizeDetection(raw) {
			if (!raw || typeof raw !== 'object') return null;
			const label = String(raw.label || raw.class || raw.name || 'object');
			const score = Number(raw.score ?? raw.confidence ?? raw.probability ?? 0);
			const box = raw.box || raw.bbox || raw.bounding_box || raw;
			let xmin = Number(box.xmin ?? box.x_min ?? box.left ?? box.x ?? 0);
			let ymin = Number(box.ymin ?? box.y_min ?? box.top ?? box.y ?? 0);
			let xmax = Number(box.xmax ?? box.x_max ?? box.right ?? 0);
			let ymax = Number(box.ymax ?? box.y_max ?? box.bottom ?? 0);
			if (![xmin, ymin, xmax, ymax, score].every(Number.isFinite)) return null;
			if (Math.max(xmin, ymin, xmax, ymax) <= 1.5) {
				xmin *= captureWidth; xmax *= captureWidth; ymin *= captureHeight; ymax *= captureHeight;
			}
			return { label, score, box: { xmin: clamp(xmin, 0, captureWidth), ymin: clamp(ymin, 0, captureHeight), xmax: clamp(xmax, 0, captureWidth), ymax: clamp(ymax, 0, captureHeight) } };
		}

		function setModel(model) {
			selectedModel = model;
			resetAssessmentState();
			refs.modelButtons.forEach((button) => button.classList.toggle('active', button.dataset.model === model));
			if (stream && !ppeManual) captureAndAssessPPE();
		}

		function setTarget(target) {
			selectedTarget = target;
			resetAssessmentState();
			refs.targetButtons.forEach((button) => button.classList.toggle('active', button.dataset.target === target));
			updateTargetCopy();
			if (stream && !ppeManual) captureAndAssessPPE();
		}

		function resetAssessmentState() {
			lastAssessment = null;
			lastAssessmentAt = null;
			lastViolationCount = 0;
			refs.activeModel.textContent = models[selectedModel];
			refs.compliant.textContent = '-';
			refs.violations.textContent = '-';
			refs.ppeLatency.textContent = '-';
			refs.lastCheck.textContent = '-';
			refs.summary.innerHTML = `<p>No ${escapeHtml(targets[selectedTarget].label)} assessment yet.</p>`;
			renderOverlay();
		}

		function updateTargetCopy() {
			const target = targets[selectedTarget];
			refs.assessmentTitle.textContent = `${target.display} status`;
			refs.emptyTitle.textContent = `Start the camera to assess ${target.label} compliance with Workers AI.`;
			refs.emptyCopy.textContent = ppeManual
				? `DETR tracks people quickly; click "Analyze frame" to run the vision model for ${target.plural}.`
				: `DETR tracks people quickly; the selected vision model checks ${target.plural} every few seconds.`;
			refs.compliantLabel.textContent = `With ${target.label}`;
			refs.violationLabel.textContent = `Missing ${target.label}`;
		}

		function roundedRect(ctx, x, y, width, height, radius) {
			ctx.beginPath();
			ctx.moveTo(x + radius, y);
			ctx.lineTo(x + width - radius, y);
			ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
			ctx.lineTo(x + width, y + height - radius);
			ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);
			ctx.lineTo(x + radius, y + height);
			ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
			ctx.lineTo(x, y + radius);
			ctx.quadraticCurveTo(x, y, x + radius, y);
			ctx.closePath();
		}

		function clamp(value, min, max) { return Math.min(Math.max(value, min), max); }
		function escapeHtml(value) { return String(value).replace(/[&<>"]/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[char]); }

		const resizeObserver = new ResizeObserver(sizeCanvases);
		resizeObserver.observe(refs.stage);
		refs.startButton.addEventListener('click', startCamera);
		refs.analyzeButton.addEventListener('click', () => { if (stream) captureAndAssessPPE(); });
		refs.pauseButton.addEventListener('click', stopCamera);
		refs.switchButton.addEventListener('click', switchCamera);
		refs.modelButtons.forEach((button) => button.addEventListener('click', () => setModel(button.dataset.model)));
		refs.targetButtons.forEach((button) => button.addEventListener('click', () => setTarget(button.dataset.target)));
		document.addEventListener('visibilitychange', () => { if (document.hidden) stopLoops(); else if (stream) startLoops(); });
		window.addEventListener('beforeunload', stopCamera);
		renderEvents();
		updateTargetCopy();

		// Confirm runtime mode: demo => manual single-shot vision; self-host => continuous.
		window.__demoStatus =
			window.__demoStatus ||
			fetch('/api/demo-status')
				.then((r) => (r.ok ? r.json() : Promise.reject(new Error('status'))))
				.catch(() => ({ demoMode: true, ppe: { manual: true } }));
		window.__demoStatus.then((status) => {
			ppeManual = !!(status && status.ppe && status.ppe.manual);
			configureMode();
		});
	})();
</script>

