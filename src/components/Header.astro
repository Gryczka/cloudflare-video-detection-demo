---
import NavTabs from './NavTabs.astro';
---

<header class="site-header">
	<div class="container header-inner">
		<a class="brand" href="/" aria-label="Workers AI Vision home">
			<svg class="brand-logo" viewBox="0 0 66 30" aria-hidden="true">
				<path
					d="M52.688 13.028c-.22 0-.437.008-.654.015a.3.3 0 0 0-.102.024.37.37 0 0 0-.236.255l-.93 3.249c-.401 1.397-.252 2.687.422 3.634.618.876 1.646 1.39 2.894 1.45l5.045.306a.45.45 0 0 1 .435.41.5.5 0 0 1-.025.223.64.64 0 0 1-.547.426l-5.242.306c-2.848.132-5.912 2.456-6.987 5.29l-.378 1a.28.28 0 0 0 .248.382h18.054a.48.48 0 0 0 .464-.35c.32-1.153.482-2.344.48-3.54 0-7.22-5.79-13.072-12.933-13.072M44.807 29.578l.334-1.175c.402-1.397.253-2.687-.42-3.634-.62-.876-1.647-1.39-2.896-1.45l-23.665-.306a.47.47 0 0 1-.374-.199.5.5 0 0 1-.052-.434.64.64 0 0 1 .552-.426l23.886-.306c2.836-.131 5.9-2.456 6.975-5.29l1.362-3.6a.9.9 0 0 0 .04-.477C48.997 5.259 42.789 0 35.367 0c-6.842 0-12.647 4.462-14.73 10.665a6.92 6.92 0 0 0-4.911-1.374c-3.28.33-5.92 3.002-6.246 6.318a7.2 7.2 0 0 0 .18 2.472C4.3 18.241 0 22.679 0 28.133q0 .74.106 1.453a.46.46 0 0 0 .457.402h43.704a.57.57 0 0 0 .54-.418"
				></path>
			</svg>
			<span class="brand-copy">
				<span>Cloudflare</span>
				<strong>Workers AI Vision</strong>
			</span>
		</a>

		<NavTabs />

		<nav class="header-actions" aria-label="Primary">
			<a class="button button-ghost" href="https://developers.cloudflare.com/workers-ai/models/detr-resnet-50/">
				Model docs
			</a>
			<a class="button button-primary" href="https://developers.cloudflare.com/workers-ai/get-started/workers-wrangler/">
				Get Workers AI
			</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		background: color-mix(in srgb, var(--cf-bg-100) 88%, transparent);
		border-bottom: 1px solid var(--cf-border);
		backdrop-filter: blur(10px);
	}

	.header-inner {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding-block: 14px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: var(--cf-text);
		text-decoration: none;
	}

	.brand-logo {
		width: 66px;
		height: 30px;
		color: var(--cf-orange);
		fill: currentColor;
	}

	.brand-copy {
		display: none;
		flex-direction: column;
		gap: 2px;
	}

	.brand-copy span {
		font-size: 9px;
		line-height: 1;
		text-transform: uppercase;
	}

	.brand-copy strong {
		font-size: 22px;
		font-weight: 500;
		line-height: 0.92;
		letter-spacing: -0.46px;
	}

	.header-actions {
		display: flex;
		align-items: center;
		margin-left: auto;
		gap: 10px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 42px;
		padding: 10px 18px;
		font-size: 14px;
		font-weight: 500;
		line-height: 1;
		text-decoration: none;
		border: 1px solid transparent;
		border-radius: var(--radius-full);
	}

	.button-primary {
		color: var(--cf-bg-100);
		background: var(--cf-orange);
	}

	.button-primary:hover {
		opacity: 0.95;
		border-color: color-mix(in srgb, var(--cf-bg-100) 50%, transparent);
		border-style: dashed;
	}

	.button-ghost {
		display: none;
		color: var(--cf-orange);
		background: transparent;
		border-color: var(--cf-border);
	}

	.button-ghost:hover {
		color: var(--cf-text);
		border-color: var(--cf-orange);
		border-style: dashed;
	}

	@media (min-width: 640px) {
		.button-ghost {
			display: inline-flex;
		}
	}

	@media (min-width: 860px) {
		.header-inner {
			flex-wrap: nowrap;
			padding-block: 18px;
		}

		.brand-copy {
			display: flex;
		}
	}
</style>
